{
  "name": "play2",
  "version": "1.0.0",
  "type": "module",
  "description": "",
  "main": "index.js",
  "scripts": {
    "clean-report": "rimraf reports",
    "test": "npm run clean-report && cucumber-js --format json:reports/report.json",
    "report": "node generate-report.js",
    "test:with-report": "npm run test && npm run report",
    "test:api": "playwright test tests/api.spec.js",
    "test:api:report": "npm run test:api && npx playwright show-report",
    "test:newman": "newman run postman-collection.json -r json,html --reporter-json-export newman-report.json --reporter-html-export newman-report.html",
    "test:all": "npm run test:api && npm run test:newman"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@applitools/eyes-playwright": "^1.38.0",
    "@azure/microsoft-playwright-testing": "^1.0.0-beta.7",
    "@playwright/test": "^1.54.1",
    "cucumber-html-reporter": "^7.2.0",
    "dotenv": "^17.2.0",
    "jest": "^29.4.3",
    "multiple-cucumber-html-reporter": "^3.9.3",
    "newman": "^4.6.1",
    "newman-reporter-html": "^1.0.5",
    "playwright": "^1.54.1",
    "rimraf": "^6.0.1"
  },
  "dependencies": {
    "@cucumber/cucumber": "^12.0.0",
    "exceljs": "^4.4.0"
  }
}
